# Minimal test Dockerfile - just test pip install
FROM python:3.10-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements-prod.txt .

# Test pip install with verbose output
RUN pip install --no-cache-dir -v -r requirements-prod.txt

# Simple test
CMD ["python", "-c", "import chromadb, gradio; print('✅ All imports successful!')"]
